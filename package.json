{
    "name": "huong-thao-tea-root",
    "version": "1.0.0",
    "scripts": {
        "start": "node server/server.js",
        "server": "npm run dev --prefix server",
        "client": "npm run dev --prefix client",
        "wellness": "npm run dev --prefix wellness",
        "dev": "concurrently \"npm run server\" \"npm run client\"",
        "dev:wellness": "concurrently \"npm run server\" \"npm run wellness\""
    },
    "dependencies": {
        "concurrently": "^8.2.2"
    }
}
